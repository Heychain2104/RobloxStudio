fetch("data/items.json")
  .then(res => {
    if (!res.ok) {
      throw new Error("No se pudo cargar el JSON: " + res.status);
    }
    return res.json();
  })
  .then(data => {
    console.log("JSON cargado:", data);

    items = data;

    // 🔥 seguridad extra
    if (!Array.isArray(items)) {
      console.error("ERROR: items no es array", items);
      return;
    }

    buildCatalog();
  })
  .catch(err => {
    console.error("Error cargando JSON:", err);
  });
